{"schema_version":"diptrace-serializer-reference-v1","generated_from":"user-supplied serializer-derived documentation and AI context pack","serializer_revision_claim":"7276","serializer_revision_authenticated":false,"trust":{"classification":"user_supplied_reference","trust_effect":"none","may_constrain_implementation":true,"may_grant_roundtrip_trust":false,"requires_independent_diptrace_5_3_fixtures_for_writers":true},"sources":[{"name":"DipTrace_PCB_XML_Specification.md","sha256":"ec70cb9ecc5766c500cad4ed7c99e1d712d6e02b9e4075a59bd02ede965916b9","role":"serializer-derived","trust_effect":"none"},{"name":"DipTrace_Schematic_XML_Specification.md","sha256":"d6ed68ae448b453841ba7b83aff51dccf9966450b55f7cc4d58e0265d31f080a","role":"serializer-derived","trust_effect":"none"},{"name":"DipTrace_CompEdit_XML_Specification.md","sha256":"cf76b6698cab8fa5300e48003a0516e4a53d0e2b58259d40439c600f8ac6fc48","role":"serializer-derived","trust_effect":"none"},{"name":"DipTrace_PattEdit_XML_Specification.md","sha256":"b000a248bdbf7a2f17d24a12b9453928c8a4c1a2b96388800b085aa52838bdf3","role":"serializer-derived","trust_effect":"none"},{"name":"01_plugin_architecture.md","sha256":"1ff3a4ebc2efe1f2c6c00774c094c796c6b5ad5d2e83a1a428e24656a02ea00d","role":"agent-context-pack","trust_effect":"none"},{"name":"02_diptrace_xml_conventions.md","sha256":"bc394b87c01b59c8152e513a38467a311057f0ba9812e008d5f146613e6d2e56","role":"agent-context-pack","trust_effect":"none"},{"name":"10_pcb_xml_reference.md","sha256":"2f00698fba0e7a0f54e38ec828f7156fe6947efef75780260a4730aee6d2d223","role":"agent-context-pack","trust_effect":"none"},{"name":"20_schematic_xml_reference.md","sha256":"f010c7f29daed2a474ec27b2e96f760941cd7f83a078bb7d4351c1a561c28958","role":"agent-context-pack","trust_effect":"none"},{"name":"30_compedit_xml_reference.md","sha256":"e2178030ca0d09972dca821dd5598a146b840fdafc47141f9823104f6dba1d36","role":"agent-context-pack","trust_effect":"none"},{"name":"40_pattedit_xml_reference.md","sha256":"c4af40003ba20021ca21106ab1ce0945875a44b8d073a1fed7d27bec06b047a2","role":"agent-context-pack","trust_effect":"none"},{"name":"50_common_operations.md","sha256":"338cdfa5ab1e6df45256cb072a63b1173eea8e8634018a2263a1d94f3486673c","role":"agent-context-pack","trust_effect":"none"},{"name":"60_common_mistakes.md","sha256":"d1b38e4477ac9dd70251c79c7221315debb952a060d34172b9731ff92fdcf981","role":"agent-context-pack","trust_effect":"none"},{"name":"README.md","sha256":"23d5c0456ea8d6e168a7c784f6bc8c2019763213a953f49bd628ad9e3023994a","role":"agent-context-pack","trust_effect":"none"}],"cross_cutting_behaviors":[{"id":"shared.units.root","title":"Root Units govern every Real geometry value","behavior":"Units is mm, inch, or mil; there is no per-object geometry unit override.","writer_requirement":"Preserve root Units and write geometry in that unit."},{"id":"shared.real.decimal-dot","title":"Canonical decimal separator is a dot","behavior":"DipTrace may read locale commas defensively, but canonical emitted Real values use a dot.","writer_requirement":"Always emit dot-decimal numbers."},{"id":"shared.angle.radians","title":"Ordinary angles are radians CCW","behavior":"Angle fields are radians counter-clockwise unless the field is explicitly a discrete Orientation enum. Model3D Rotate is degrees.","writer_requirement":"Do not serialize placement/shape angles as degrees."},{"id":"shared.ids.edit","title":"Edit import is keyed by existing top-level Id","behavior":"Under ImpMode=Edit, preserve Id for edits; omit Id for additions rather than guessing a free value.","writer_requirement":"Never renumber existing IDs during an edit transaction."},{"id":"shared.full-file.dense-ids","title":"Whole-file top-level arrays are positional","behavior":"For whole-file generation, top-level arrays must be dense and ordered from Id 0 with position equal to Id.","writer_requirement":"Do not use sparse/reordered top-level arrays in generated whole files."},{"id":"shared.enabled.delete","title":"Enabled=N is an import delete flag","behavior":"On supported edit-import objects, Enabled=N means delete; absent means enabled. Normal saves often prune disabled objects.","writer_requirement":"For edit-import deletion, retain the node and set Enabled=N when that object supports the flag."},{"id":"shared.selected.filter","title":"Selected filter skips unselected incoming objects","behavior":"With PCB/Schematic Selected filtering under Edit, incoming objects without Selected=Y are skipped, including new objects.","writer_requirement":"Set Selected=Y on every edited/added object when a Selected filter is active."},{"id":"shared.nested-list.replace","title":"Nested ID-less lists are replacement containers","behavior":"Traces, net/bus Wires, and point lists are replaced wholesale when their container is present; they are not member-merged.","writer_requirement":"Omit an untouched container or re-list all current children plus changes."},{"id":"shared.unknown.preserve","title":"Unknown XML is forward-compatible state","behavior":"Newer serializer fields may not exist in older published tables.","writer_requirement":"Preserve unknown attributes/elements during targeted edits."},{"id":"shared.points.canonical","title":"Canonical geometry vertices use Point","behavior":"Geometry point containers canonically emit Point; readers may accept Item. Mask/paste segment rectangles are a documented Item exception.","writer_requirement":"Emit Point for ordinary geometry and Item only f