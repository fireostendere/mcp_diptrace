 only","reader_notes":"Accept legacy PatternType alias; writer emits Style."},{"id":"component.pin.electric_type","dialect":"component_library","path":"/Library/Components/Component/Part/Pins/Pin","field":"@ElectricType","type":"enum","semantics":"ERC electrical type.","values":["Undefined","Passive","Input","Output","Bidirectional","Open High","Open Low","Passive High","Passive Low","3 State","Power"],"written_when":"always"},{"id":"component.pin.orientation","dialect":"component_library","path":"/Library/Components/Component/Part/Pins/Pin","field":"@Orientation","type":"enum","semantics":"Discrete pin direction in degrees.","values":["0","90","180","270"],"written_when":"always"},{"id":"component.pin.pad_id","dialect":"component_library","path":"/Library/Components/Component/Part/Pins/Pin","field":"@PadId","type":"int","semantics":"Numeric index into attached footprint pad array.","written_when":"always","reader_notes":"Accept legacy PadIndex alias; writer emits PadId."},{"id":"component.pin.pad_number","dialect":"component_library","path":"/Library/Components/Component/Part/Pins/Pin/PadNumber","field":"#text","type":"text","semantics":"Footprint pad name paired with PadId.","written_when":"if present"},{"id":"component.internal_connection","dialect":"component_library","path":"/Library/Components/Component/Part/InternalConnections/IntCon","field":"@X/@Y","type":"id-reference","semantics":"Both values reference footprint pad Id values, not coordinates.","written_when":"if internal short exists","writer_notes":"Deleting/renumbering pads requires updating every IntCon reference."},{"id":"component.add_field.type","dialect":"component_library","path":"/Library/Components/Component/Part/AddFields/AddField","field":"@Type","type":"enum","semantics":"User field type.","values":["Text","Link"],"written_when":"always"},{"id":"pcb.component.type","dialect":"pcb","path":"/Source/Board/Components/Component","field":"@Type","type":"enum","semantics":"Special standalone object kind; absent for ordinary footprint components.","values":["Pad","MtHole","Via","Fiducial"],"written_when":"special object only"},{"id":"pcb.component.angle","dialect":"pcb","path":"/Source/Board/Components/Component","field":"@Angle","type":"real","semantics":"Placed component rotation in radians CCW.","default":"0 (omitted)","written_when":"if nonzero"},{"id":"pcb.component.side","dialect":"pcb","path":"/Source/Board/Components/Component","field":"@Side","type":"enum","semantics":"Placed component side.","values":["Top","Bottom"],"written_when":"ordinary components"},{"id":"pcb.pad.net_id","dialect":"pcb","path":"/Source/Board/Components/Component/Pads/Pad","field":"@NetId","type":"int","semantics":"Authoritative pad net membership; -1 means unconnected.","written_when":"always","writer_notes":"Do not rely on Net/Pads mirror alone to move a pad between nets."},{"id":"pcb.net.net_class","dialect":"pcb","path":"/Source/Board/Nets/Net","field":"@NetClass","type":"positional-index","semantics":"Index into ordered NetClasses list, not an Id lookup.","written_when":"always"},{"id":"pcb.net.pads","dialect":"pcb","path":"/Source/Board/Nets/Net/Pads/Item","field":"@Comp/@Pad","type":"id-reference","semantics":"Derived mirror of component pad memberships.","written_when":"members exist"},{"id":"pcb.trace.endpoints","dialect":"pcb","path":"/Source/Board/Nets/Net/Traces/Trace","field":"@Connected1,Object1,SubObject1,Point1 / @Connected2,Object2,SubObject2,Point2","type":"endpoint-reference","semantics":"Trace connectivity is declared by endpoint references, not geometric touching.","written_when":"trace present"},{"id":"pcb.trace.point.layer","dialect":"pcb","path":"/Source/Board/Nets/Net/Traces/Trace/Points/Point","field":"@Lay","type":"layer-id","semantics":"Numeric copper layer Id stored on a point/segment end.","written_when":"point present","writer_notes":"Do not replace with textual Layer."},{"id":"pcb.trace.point.via_style","dialect":"pcb","path":"/Source/Board/Nets/Net/Traces/Trace/Points/Point","field":"@ViaStyle","type":"positional-index","semantics":"Via-style reference; concrete via geometry is rebuilt from the style.","written_when":"via at point"},{"id":"pcb.trace.point.width","dialect":"pcb","path":"/Source/Board/Nets/Net/Traces/Trace/Points/Point","field":"@Width","type":"real","semantics":"Segment width lives on the segment end point.","written_when":"segment attribute present"},{"id":"pcb.shape.layer","dialect":"pcb","path":"/Source/Board/Shapes/Shape","field":"@Layer/@LayId","type":"text+id","semantics":"Layer is textual name; LayId is numeric layer reference where applicable.","written_when":"shape present"},{"id":"pcb.copper_pour.layer","dialect":"pcb","path":"/Source/Board/CopperPours/CopperPour","field":"@Lay","type":"layer-id","semantics":"Numeric copper layer Id.","written_when":"always"},{"id":"pcb.via_style.reference","dialect":"pcb","path":"/Source/Board/ViaStyles/ViaStyle","field":"list-position","type":"positional-list","semantics":"References to via styles are positional in serializer behavior.","written_when":"via styles present","writer_notes":"Do not reorder the list casually."},{"id":"pcb.ratlines.derived","dialect":"pcb","path":"/Source/Board/Ratlines","field":"derived","type":"derived-state","semantics":"Ratlines are generated from pad net membership; they are not authoritative connectivity.","written_when":"export may include them"},{"id":"schematic.part.angle","dialect":"schematic","path":"/Source/Schematic