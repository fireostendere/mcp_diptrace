"write_condition":"always","enum_values":["Top Silk","Top Assy","Top Mask","Top Paste","Bottom Paste","Bottom Mask","Bottom Assy","Bottom Silk","Top","Top Keepout","Bottom Keepout","Bottom","Board Cutout","Top Dimension","Bottom Dimension","Non-Signal","Top Courtyard","Bottom Courtyard","Top Outline","Bottom Outline","Top Terminals","Bottom Terminals"],"meaning":"Literal pattern shape layer name","source_id":"pattedit_serializer_7276","source_section":"<Shape>"},{"id":"shape.angle","dialects":["pattern_library","component_library","pcb"],"element":"Shape","attribute":"Angle","value_type":"real","default":0,"write_condition":"when applicable","enum_values":[],"meaning":"Shape/text rotation uses radians counter-clockwise unless explicitly documented ","source_id":"pattedit_serializer_7276","source_section":"Coordinate frames, units & angle"},{"id":"model3d.rotate","dialects":["pattern_library","component_library","pcb"],"element":"Model3D/Rotate","attribute":"X,Y,Z","value_type":"real_tuple","default":0,"write_condition":"always","enum_values":[],"meaning":"3D model rotations are degrees, unlike ordinary XML Angle fields.","source_id":"pattedit_serializer_7276","source_section":"Coordinate frames, units & angle"},{"id":"geometry.points","dialects":["pattern_library","component_library","pcb","schematic"],"element":"Points","attribute":"Point","value_type":"element","default":null,"write_condition":"always","enum_values":[],"meaning":"Geometry point containers normally use Point children","source_id":"pcb_serializer_7276","source_section":"Points / Point"},{"id":"trace.point.layer","dialects":["pcb"],"element":"Net/Traces/Trace/Points/Point","attribute":"Lay","value_type":"int_ref","default":null,"write_condition":"always","enum_values":[],"meaning":"Numeric copper-layer Id, not a textual Layer name.","source_id":"pcb_serializer_7276","source_section":"Points / Point (trace)"},{"id":"trace.point.viastyle","dialects":["pcb"],"element":"Net/Traces/Trace/Points/Point","attribute":"ViaStyle","value_type":"int_ref","default":-1,"write_condition":"always","enum_values":[],"meaning":"Via-style reference/index","source_id":"pcb_serializer_7276","source_section":"Points / Point (trace)"},{"id":"component.angle","dialects":["pcb","schematic"],"element":"placed component/part","attribute":"Angle","value_type":"real","default":0,"write_condition":"always","enum_values":[],"meaning":"Placed object rotation is radians counter-clockwise.","source_id":"pcb_serializer_7276","source_section":"Coordinate frames, units & angle"},{"id":"component.side","dialects":["pcb"],"element":"Component","attribute":"Side","value_type":"enum","default":"Top","write_condition":"always","enum_values":["Top","Bottom"],"meaning":"Placed PCB side.","source_id":"pcb_serializer_7276","source_section":"Components"},{"id":"pin.orientation","dialects":["component_library","schematic"],"element":"Pin","attribute":"Orientation","value_type":"enum","default":"0","write_condition":"always","enum_values":["0","90","180","270"],"meaning":"Discrete symbol-pin orientation, not a radian angle.","source_id":"compedit_serializer_7276","source_section":"Pins"},{"id":"root.version","dialects":["pcb","schematic","component_library","pattern_library"],"element":"root","attribute":"Version","value_type":"text","default":null,"write_condition":"preserve existing value during edits","enum_values":[],"meaning":"Do not synthesize or upgrade Version while editing an existing document.","source_id":"pcb_serializer_7276","source_section":"Document structure"}],"behaviors":[{"id":"import.all.replaces_list","scope":["pcb","schematic","component_library","pattern_library"],"rule":"Whole-list import modes replace the target list; omitted members are removed.","risk":"destructive_omission","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]},{"id":"import.edit.matches_top_level_id","scope":["pcb","schematic","component_library","pattern_library"],"rule":"Edit matches existing top-level objects by Id; keep existing Id to edit and omit Id for new objects.","risk":"id_collision_or_overwrite","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]},{"id":"import.nested_lists.replace","scope":["pcb","schematic"],"rule":"Nested lists without per-member Id, including Traces/Wires/Points, are replaced when the container is present; they are not merged member-by-member.","risk":"routing_or_wiring_loss","source_ids":["pcb_serializer_7276","schematic_serializer_7276"]},{"id":"import.selected_filter.skips_unselected","scope":["pcb","schematic"],"rule":"Under a Selected filter with Edit, only objects marked Selected=Y are processed; unmarked new or edited objects are skipped.","risk":"silent_drop","source_ids":["pcb_serializer_7276","schematic_serializer_7276"]},{"id":"import.delete.enabled_n","scope":["pcb","schematic","component_library","pattern_library"],"rule":"Delete editable objects on import with Enabled=N while leaving the node present; normal saves may prune disabled nodes.","risk":"wrong_delete_semantics","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]},{"id":"full_file.ids_dense_positional","scope":["pcb","schematic","component_library","pattern_library"],"rule":"When authoring a whole file, referenced top-level arrays must remain dense/in-order where the reader resolves references positionally.","risk":"reference_rebinding","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]},{"id":"edit.preserve_unknown_xml","scope":["pcb","schematic","component_library","pattern_library"],"rule":"Preserve unknown attributes/elements when editing in place; newer serializer fields may be absent from older published tables.","risk":"data_loss","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]},{"id":"trust.reference_only","scope":["mcp"],"rule":"Serializer-derived documentation is reference-only. It may constrain parsing/writing and tests but cannot grant diptrace_exported/open-save/roundtrip trust without independent fixture evidence.","risk":"trust_escalation","source_ids":["pattedit_serializer_7276","compedit_serializer_7276","pcb_serializer_7276","schematic_serializer_7276"]}]}
