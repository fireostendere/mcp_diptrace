/Components/Part","field":"@Angle","type":"real","semantics":"Placed part rotation in radians CCW.","default":"0 (omitted)","written_when":"if nonzero"},{"id":"schematic.part.pin.net_id","dialect":"schematic","path":"/Source/Schematic/Components/Part/Pins/Pin","field":"@NetId","type":"int","semantics":"Connected net Id or -1.","written_when":"always"},{"id":"schematic.part.pin.not_connected","dialect":"schematic","path":"/Source/Schematic/Components/Part/Pins/Pin","field":"@NotConnected","type":"bool","semantics":"Explicit no-connect state.","default":"N (omitted)","written_when":"if set"},{"id":"schematic.net.net_class","dialect":"schematic","path":"/Source/Schematic/Nets/Net","field":"@NetClass","type":"positional-index","semantics":"Index into ordered NetClasses list.","written_when":"always"},{"id":"schematic.net.enabled","dialect":"schematic","path":"/Source/Schematic/Nets/Net","field":"@Enabled","type":"bool","semantics":"Deleted net marker.","default":"enabled/omitted","written_when":"N only for deleted net"},{"id":"schematic.net.pins","dialect":"schematic","path":"/Source/Schematic/Nets/Net/Pins/Item","field":"@Part/@Pin","type":"id+position-reference","semantics":"Part Id plus positional pin index.","written_when":"members exist"},{"id":"schematic.wire.dir","dialect":"schematic","path":"/Source/Schematic/Nets/Net/Wires/Wire/Points/Point","field":"@Dir","type":"enum-int","semantics":"Segment direction on segment end: -1 unset, 0 horizontal, 1 vertical.","values":["-1","0","1"],"written_when":"point present"},{"id":"schematic.wire.endpoints","dialect":"schematic","path":"/Source/Schematic/Nets/Net/Wires/Wire","field":"@Connected1/2,Bus1/2,Object1/2,SubObject1/2","type":"endpoint-reference","semantics":"Wire endpoints bind to pins/wires/buses by ids and point indexes.","written_when":"wire present"},{"id":"schematic.diffpair.nets","dialect":"schematic","path":"/Source/Schematic/DifferentialPairs/DifferentialPair","field":"@PosNet/@NegNet","type":"net-id","semantics":"Positive and negative net Id references.","written_when":"pair present"},{"id":"schematic.bus.members","dialect":"schematic","path":"/Source/Schematic/Buses/Bus/Nets/Net","field":"@NetId/@ConnectionNumber","type":"net-reference","semantics":"Bus member net Id and ordinal.","written_when":"member exists"},{"id":"schematic.shape.net_bus","dialect":"schematic","path":"/Source/Schematic/Shapes/Shape","field":"@NetId/@BusId","type":"id-reference","semantics":"Text shapes may be bound as net/bus labels.","written_when":"Text shape and binding present"}]}