or documented reference/segment lists."},{"id":"shared.segment.second-point","title":"Segment parameters live on the segment end point","behavior":"PCB trace and Schematic wire per-segment attributes are stored on the second/end Point; the first point carries geometry identity only.","writer_requirement":"When splitting/extending a path, move segment attributes to the correct end point."},{"id":"shared.paths.path-var","title":"External file references preserve Path and Var","behavior":"Library/picture/3D file references may carry resolved Path and environment-variable Var forms.","writer_requirement":"Preserve both representations when present."},{"id":"plugin.exchange.same-file","title":"Plugin exchange is overwrite-in-place","behavior":"DipTrace passes plugin_exchange.xml as argv[1], waits for the process, then reads the same path back.","writer_requirement":"Modify the supplied exchange path; do not create a replacement path."},{"id":"plugin.type.namespaces","title":"Plugin and data Type namespaces differ","behavior":"settings.xml uses underscore plugin types while exchange XML uses hyphenated DipTrace-PCB / DipTrace-Schematic data types.","writer_requirement":"Do not mix settings.xml Type values with data XML root Type values."}],"rules":[{"id":"pcb.root.type","dialect":"pcb","path":"/Source","field":"@Type","type":"literal","semantics":"Document dialect identifier.","values":["DipTrace-PCB"],"written_when":"always"},{"id":"pcb.root.units","dialect":"pcb","path":"/Source","field":"@Units","type":"enum","semantics":"Unit for every Real geometry/length value.","values":["mm","inch","mil"],"written_when":"always"},{"id":"schematic.root.type","dialect":"schematic","path":"/Source","field":"@Type","type":"literal","semantics":"Document dialect identifier.","values":["DipTrace-Schematic"],"written_when":"always"},{"id":"schematic.root.units","dialect":"schematic","path":"/Source","field":"@Units","type":"enum","semantics":"Unit for every Real geometry/length value.","values":["mm","inch","mil"],"written_when":"always"},{"id":"component_library.root.type","dialect":"component_library","path":"/Library","field":"@Type","type":"literal","semantics":"Document dialect identifier.","values":["DipTrace-ComponentLibrary"],"written_when":"always"},{"id":"component_library.root.units","dialect":"component_library","path":"/Library","field":"@Units","type":"enum","semantics":"Unit for every Real geometry/length value.","values":["mm","inch","mil"],"written_when":"always"},{"id":"pattern_library.root.type","dialect":"pattern_library","path":"/Library","field":"@Type","type":"literal","semantics":"Document dialect identifier.","values":["DipTrace-PatternLibrary"],"written_when":"always"},{"id":"pattern_library.root.units","dialect":"pattern_library","path":"/Library","field":"@Units","type":"enum","semantics":"Unit for every Real geometry/length value.","values":["mm","inch","mil"],"written_when":"always"},{"id":"pattern.padstyle.type","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle","field":"@Type","type":"enum","semantics":"Pad kind.","values":["Surface","Through"],"written_when":"always"},{"id":"pattern.padstyle.hole_type","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle","field":"@HoleType","type":"enum","semantics":"Drill shape for Through pads.","values":["Round","Obround"],"written_when":"Through only"},{"id":"pattern.padstyle.hole","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle","field":"@Hole","type":"real","semantics":"Through-pad drill diameter/width; for a Fiducial MainStack it instead means fiducial keepout diameter.","written_when":"Through or Fiducial","writer_notes":"Do not treat Fiducial Hole as a drill."},{"id":"pattern.padstyle.holeh","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle","field":"@HoleH","type":"real","semantics":"Obround drill height; no fiducial meaning.","written_when":"HoleType=Obround"},{"id":"pattern.mainstack.shape","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MainStack","field":"@Shape","type":"enum","semantics":"Primary copper shape.","values":["Ellipse","Obround","Rectangle","Polygon","D-shape","Fiducial"],"written_when":"always"},{"id":"pattern.mainstack.width","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MainStack","field":"@Width","type":"real","semantics":"Copper width; for Fiducial it is the copper diameter.","written_when":"always"},{"id":"pattern.mainstack.height","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MainStack","field":"@Height","type":"real","semantics":"Copper height.","written_when":"if not Fiducial","reader_notes":"For Fiducial, derive normalized height from Width rather than treating omission as zero."},{"id":"pattern.mainstack.offset","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MainStack","field":"@XOff/@YOff","type":"real","semantics":"Copper offset from drill center.","written_when":"Through only"},{"id":"pattern.mainstack.corner","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MainStack","field":"@Corner","type":"real","semantics":"Rectangle corner rounding.","written_when":"Rectangle only"},{"id":"pattern.terminal.angle","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/Terminals/Terminal","field":"@Angle","type":"real","semantics":"Secondary terminal rotation in radians CCW.","written_when":"always"},{"id":"pattern.mask.mode","dialect":"pattern_library","path":"/Library/PadStyle