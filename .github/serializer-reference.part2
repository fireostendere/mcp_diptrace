s/PadStyle/MaskPaste","field":"@TopMask/@BotMask","type":"enum","semantics":"Per-side solder mask state.","values":["Common","Open","Tented","By Paste"],"default":"Common (attribute omitted)","written_when":"if not Common"},{"id":"pattern.paste.mode","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MaskPaste","field":"@TopPaste/@BotPaste","type":"enum","semantics":"Per-side paste state.","values":["Common","Solder","No Solder","Segments"],"default":"Common (attribute omitted)","written_when":"if not Common"},{"id":"pattern.mask.custom_swell","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MaskPaste","field":"@CustomSwell","type":"real","semantics":"Custom mask swell.","default":"unset sentinel -1000","written_when":"if set","reader_notes":"Normalize -1000 to None/unset; never generate geometry from it."},{"id":"pattern.paste.custom_shrink","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MaskPaste","field":"@CustomShrink","type":"real","semantics":"Custom paste shrink.","default":"unset sentinel -1000","written_when":"if set","reader_notes":"Normalize -1000 to None/unset; never generate geometry from it."},{"id":"pattern.paste.segments","dialect":"pattern_library","path":"/Library/PadStyles/PadStyle/MaskPaste/TopSegments|BotSegments","field":"Item@X1,Y1,X2,Y2","type":"rectangle-list","semantics":"Explicit segmented paste rectangles.","written_when":"paste side is Segments","reader_notes":"These geometry children are Item, not Point."},{"id":"pattern.pattern.mounting","dialect":"pattern_library","path":"/Library/Patterns/Pattern","field":"@Mounting","type":"enum","semantics":"Footprint mounting kind; there is no None value.","values":["Through","SMD","Chassis","Mixed"],"written_when":"always","reader_notes":"Unknown/omitted must not be normalized to a fabricated None enum."},{"id":"pattern.pattern.orientation","dialect":"pattern_library","path":"/Library/Patterns/Pattern","field":"@Orientation","type":"enum","semantics":"Metadata orientation; does not rotate stored footprint geometry.","values":["0","90","180","270"],"written_when":"always"},{"id":"pattern.pattern.type","dialect":"pattern_library","path":"/Library/Patterns/Pattern","field":"@Type","type":"enum","semantics":"Creation-template type.","values":["None","Free","Right Angle","Left Angle","T","Circle","Lines","Square","Matrix","Rectangle","Zig-Zag","IPC-7351"],"written_when":"always"},{"id":"pattern.pad.side","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Pads/Pad","field":"@Side","type":"enum","semantics":"Pad side.","values":["Top","Bottom"],"written_when":"always"},{"id":"pattern.pad.angle","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Pads/Pad","field":"@Angle","type":"real","semantics":"Pad rotation in radians CCW.","written_when":"always"},{"id":"pattern.shape.type","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Shapes/Shape","field":"@Type","type":"enum","semantics":"Footprint graphic type.","values":["None","Line","Rectangle","Obround","FillRect","FillObround","Arc","Text","Polyline","Polygon"],"written_when":"always"},{"id":"pattern.shape.layer","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Shapes/Shape","field":"@Layer","type":"enum","semantics":"Textual layer literal.","values":["Top Silk","Top Assy","Top Mask","Top Paste","Bottom Paste","Bottom Mask","Bottom Assy","Bottom Silk","Top","Top Keepout","Bottom Keepout","Bottom","Board Cutout","Top Dimension","Bottom Dimension","Non-Signal","Top Courtyard","Bottom Courtyard","Top Outline","Bottom Outline","Top Terminals","Bottom Terminals"],"written_when":"always","writer_notes":"Never invent combined Top/Bottom layer names."},{"id":"pattern.hole.geometry","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Holes/Hole","field":"@Diam/@HoleDiam","type":"real","semantics":"Diam is keepout diameter; HoleDiam is drilled-hole diameter.","written_when":"always"},{"id":"pattern.model.filename","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Model3D/Filename","field":"Path/Var","type":"path-pair","semantics":"3D model path in resolved and variable forms.","written_when":"model present","reader_notes":"Filename is a container; do not read only direct element text."},{"id":"pattern.model.rotate","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Model3D/Rotate","field":"@X/@Y/@Z","type":"real","semantics":"3D model rotation components in degrees.","written_when":"always"},{"id":"pattern.model.units","dialect":"pattern_library","path":"/Library/Patterns/Pattern/Model3D","field":"@Units","type":"enum","semantics":"3D model file units.","values":["mm","mil","inch","Wings"],"written_when":"always"},{"id":"component.part.part_type","dialect":"component_library","path":"/Library/Components/Component/Part","field":"@PartType","type":"enum","semantics":"Component section role.","values":["Normal","Power","Net Port","Hierarchy Connector","Hierarchy Block"],"written_when":"always"},{"id":"component.part.show_numbers","dialect":"component_library","path":"/Library/Components/Component/Part","field":"@ShowNumbers","type":"enum","semantics":"Pin-number display mode.","values":["Common","Show","Hide"],"default":"Common (omitted)","written_when":"if > 0"},{"id":"component.pattern.style","dialect":"component_library","path":"/Library/Components/Component/Part/Pattern","field":"@Style","type":"text","semantics":"Attached footprint style key.","written_when":"first part