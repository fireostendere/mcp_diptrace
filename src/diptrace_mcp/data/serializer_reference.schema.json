{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fireostendere/mcp_diptrace/src/diptrace_mcp/data/serializer_reference.schema.json",
  "title": "DipTrace serializer-derived reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "reference_id", "reference_kind", "authority", "trust_effect",
    "serializer_revision", "claimed_generated_date", "notes", "source_documents", "rules", "behaviors"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "reference_id": {"type": "string", "minLength": 1},
    "reference_kind": {"const": "serializer_derived_documentation"},
    "authority": {"const": "user_supplied_reference"},
    "trust_effect": {"const": "none"},
    "serializer_revision": {"type": "integer", "minimum": 1},
    "claimed_generated_date": {"type": "string", "format": "date"},
    "notes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "file_name", "sha256", "description"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "file_name": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "dialects", "element", "attribute", "value_type", "default",
          "write_condition", "enum_values", "meaning", "source_id", "source_section"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
          "dialects": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "element": {"type": "string", "minLength": 1},
          "attribute": {"type": "string", "minLength": 1},
          "value_type": {"type": "string", "minLength": 1},
          "default": {},
          "write_condition": {"type": "string", "minLength": 1},
          "enum_values": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "meaning": {"type": "string", "minLength": 1},
          "source_id": {"type": "string", "minLength": 1},
          "source_section": {"type": "string", "minLength": 1}
        }
      }
    },
    "behaviors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scope", "rule", "risk", "source_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
          "scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "rule": {"type": "string", "minLength": 1},
          "risk": {"type": "string", "minLength": 1},
          "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
