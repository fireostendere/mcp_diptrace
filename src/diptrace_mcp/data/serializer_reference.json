  "cross_cutting_behaviors": [
    {
      "id": "shared.units.root",
      "title": "Root Units govern every Real geometry value",
      "behavior": "Units is mm, inch, or mil; there is no per-object geometry unit override.",
      "writer_requirement": "Preserve root Units and write geometry in that unit."
    },
    {
      "id": "shared.real.decimal-dot",
      "title": "Canonical decimal separator is a dot",
      "behavior": "DipTrace may read locale commas defensively, but canonical emitted Real values use a dot.",
      "writer_requirement": "Always emit dot-decimal numbers."
    },
    {
      "id": "shared.angle.radians",
      "title": "Ordinary angles are radians CCW",
      "behavior": "Angle fields are radians counter-clockwise unless the field is explicitly a discrete Orientation enum. Model3D Rotate is degrees.",
      "writer_requirement": "Do not serialize placement/shape angles as degrees."
    },
    {
      "id": "shared.ids.edit",
      "title": "Edit import is keyed by existing top-level Id",
      "behavior": "Under ImpMode=Edit, preserve Id for edits; omit Id for additions rather than guessing a free value.",
      "writer_requirement": "Never renumber existing IDs during an edit transaction."
    },
    {
      "id": "shared.full-file.dense-ids",
      "title": "Whole-file top-level arrays are positional",
      "behavior": "For whole-file generation, top-level arrays must be dense and ordered from Id 0 with position equal to Id.",
      "writer_requirement": "Do not use sparse/reordered top-level arrays in generated whole files."
    },
    {
      "id": "shared.enabled.delete",
      "title": "Enabled=N is an import delete flag",
      "behavior": "On supported edit-import objects, Enabled=N means delete; absent means enabled. Normal saves often prune disabled objects.",
      "writer_requirement": "For edit-import deletion, retain the node and set Enabled=N when that object supports the flag."
    },
    {
      "id": "shared.selected.filter",
      "title": "Selected filter skips unselected incoming objects",
      "behavior": "With PCB/Schematic Selected filtering under Edit, incoming objects without Selected=Y are skipped, including new objects.",
      "writer_requirement": "Set Selected=Y on every edited/added object when a Selected filter is active."
    },
    {
      "id": "shared.nested-list.replace",
      "title": "Nested ID-less lists are replacement containers",
      "behavior": "Traces, net/bus Wires, and point lists are replaced wholesale when their container is present; they are not member-merged.",
      "writer_requirement": "Omit an untouched container or re-list all current children plus changes."
    },
    {
      "id": "shared.unknown.preserve",
      "title": "Unknown XML is forward-compatible state",
      "behavior": "Newer serializer fields may not exist in older published tables.",
      "writer_requirement": "Preserve unknown attributes/elements during targeted edits."
    },
    {
      "id": "shared.points.canonical",
      "title": "Canonical geometry vertices use Point",
      "behavior": "Geometry point containers canonically emit Point; readers may accept Item. Mask/paste segment rectangles are a documented Item exception.",
      "writer_requirement": "Emit Point for ordinary geometry and Item only for documented reference/segment lists."
    },
    {
      "id": "shared.segment.second-point",
      "title": "Segment parameters live on the segment end point",
      "behavior": "PCB trace and Schematic wire per-segment attributes are stored on the second/end Point; the first point carries geometry identity only.",
      "writer_requirement": "When splitting/extending a path, move segment attributes to the correct end point."
    },
    {
      "id": "shared.paths.path-var",
      "title": "External file references preserve Path and Var",
      "behavior": "Library/picture/3D file references may carry resolved Path and environment-variable Var forms.",
      "writer_requirement": "Preserve both representations when present."
    },
    {
      "id": "plugin.exchange.same-file",
      "title": "Plugin exchange is overwrite-in-place",
      "behavior": "DipTrace passes plugin_exchange.xml as argv[1], waits for the process, then reads the same path back.",
      "writer_requirement": "Modify the supplied exchange path; do not create a replacement path."
    },
    {
      "id": "plugin.type.namespaces",
      "title": "Plugin and data Type namespaces differ",
      "behavior": "settings.xml uses underscore plugin types while exchange XML uses hyphenated DipTrace-PCB / DipTrace-Schematic data types.",
      "writer_requirement": "Do not mix settings.xml Type values with data XML root Type values."
    }
  ],
