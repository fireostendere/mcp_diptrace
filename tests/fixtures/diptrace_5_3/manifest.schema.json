{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/diptrace-mcp/diptrace-5.3-fixture-manifest.schema.json",
  "title": "DipTrace 5.3 Fixture Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "diptrace",
    "redistribution",
    "fixtures"
  ],
  "properties": {
    "schema_version": {
      "const": "diptrace-fixture-manifest-v2"
    },
    "diptrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "build", "operating_system"],
      "properties": {
        "version": {"type": "string", "pattern": "^5\\.3(?:\\.|$)"},
        "build": {"type": "string", "minLength": 1, "maxLength": 128},
        "operating_system": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "redistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["permitted", "basis"],
      "properties": {
        "permitted": {"const": true},
        "basis": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "source_type",
          "sha256",
          "validation_level",
          "provenance",
          "workflow",
          "purpose"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.() -]+(?:/[A-Za-z0-9_.() -]+)*$",
            "maxLength": 512
          },
          "source_type": {
            "enum": [
              "DipTrace-PCB",
              "DipTrace-Schematic",
              "DipTrace-ComponentLibrary",
              "DipTrace-PatternLibrary",
              "Specctra-DSN",
              "Specctra-SES"
            ]
          },
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "validation_level": {
            "enum": [
              "synthetic_parser_only",
              "synthetic_operation_fixture",
              "diptrace_exported",
              "diptrace_open_save_verified",
              "diptrace_roundtrip_verified",
              "external_tool_roundtrip_verified"
            ]
          },
          "provenance": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "units": {"enum": ["mm", "inch", "mil", "not_applicable"]},
          "workflow": {"type": "string", "minLength": 1, "maxLength": 1000},
          "purpose": {"type": "string", "minLength": 1, "maxLength": 1000},
          "format_version": {
            "type": "string",
            "description": "XML Version attribute of the source document."
          },
          "diptrace_version": {
            "type": "string",
            "description": "Exact DipTrace version if DipTrace was involved in creation."
          },
          "diptrace_build": {
            "type": "string",
            "description": "DipTrace build identifier."
          },
          "diptrace_opened": {
            "type": "boolean",
            "default": false
          },
          "diptrace_saved": {
            "type": "boolean",
            "default": false
          },
          "diptrace_reexported": {
            "type": "boolean",
            "default": false
          },
          "reexport_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "roundtrip_verified": {
            "type": "boolean",
            "default": false
          },
          "semantic_comparison_passed": {
            "type": ["boolean", "null"]
          },
          "known_limitations": {
            "type": "array",
            "items": {"type": "string"},
            "default": []
          },
          "difference_from": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "single_change"],
            "properties": {
              "path": {"type": "string", "minLength": 1, "maxLength": 512},
              "single_change": {"type": "string", "minLength": 1, "maxLength": 1000}
            }
          }
        },
        "allOf": [
          {
            "if": {"properties": {"validation_level": {"const": "diptrace_exported"}}},
            "then": {
              "required": ["diptrace_version", "sha256", "provenance", "format_version"]
            }
          },
          {
            "if": {"properties": {"validation_level": {"const": "diptrace_open_save_verified"}}},
            "then": {
              "required": ["diptrace_version", "diptrace_opened", "diptrace_saved", "diptrace_build"],
              "properties": {
                "diptrace_opened": {"const": true},
                "diptrace_saved": {"const": true}
              }
            }
          },
          {
            "if": {"properties": {"validation_level": {"const": "diptrace_roundtrip_verified"}}},
            "then": {
              "required": [
                "diptrace_version",
                "diptrace_build",
                "diptrace_opened",
                "diptrace_saved",
                "diptrace_reexported",
                "reexport_sha256",
                "roundtrip_verified",
                "semantic_comparison_passed"
              ],
              "properties": {
                "diptrace_opened": {"const": true},
                "diptrace_saved": {"const": true},
                "diptrace_reexported": {"const": true},
                "roundtrip_verified": {"const": true},
                "semantic_comparison_passed": {"const": true}
              }
            }
          },
          {
            "if": {"properties": {"validation_level": {"const": "external_tool_roundtrip_verified"}}},
            "then": {
              "required": [
                "diptrace_version",
                "diptrace_build",
                "diptrace_opened",
                "diptrace_saved",
                "diptrace_reexported",
                "reexport_sha256",
                "roundtrip_verified",
                "semantic_comparison_passed"
              ],
              "properties": {
                "diptrace_opened": {"const": true},
                "diptrace_saved": {"const": true},
                "diptrace_reexported": {"const": true},
                "roundtrip_verified": {"const": true},
                "semantic_comparison_passed": {"const": true}
              }
            }
          }
        ]
      }
    }
  }
}
